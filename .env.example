# ---------------------------------------------------------------------------
# Agent Forge — environment template
# Copy to `.env.local` (gitignored) and fill in a key for one provider.
# ---------------------------------------------------------------------------

# Which provider Forge uses to BUILD and RUN agents: "anthropic" or "openai".
# Overridable per-command with --provider.
LLM_PROVIDER=anthropic

# Provide the key for whichever provider you select (both is fine).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional model overrides (defaults: claude-opus-4-8 / gpt-4.1)
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4.1
