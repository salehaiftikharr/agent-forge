# ---------------------------------------------------------------------------
# Agent Forge — environment template
# Copy to `.env.local` (gitignored) and fill in a key for one provider.
# ---------------------------------------------------------------------------

# Which provider Forge uses to BUILD and RUN agents: "anthropic" or "openai".
# Overridable per-command with --provider.
LLM_PROVIDER=anthropic

# Provide the key for whichever provider you select (both is fine).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional model overrides (defaults: claude-opus-4-8 / gpt-4.1)
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4.1

# ---- Slack bot (npm run slack) — "message your minions" ----
# Socket Mode, so no public URL is needed. See the README for how to get these.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# Optional: a default repo so you can say "fix issue 3" without naming it.
# MINION_DEFAULT_REPO=salehaiftikharr/forge-minions-demo

# ---- Linear (optional) — work off Linear issues, e.g. "fix ENG-123 in owner/repo" ----
# Linear → Settings → API → Personal API keys.
# LINEAR_API_KEY=lin_api_...

# ---- Test runner (optional) ----
# Minions auto-detect how a repo runs its tests (vitest, jest, mocha, go,
# node:test, or an npm "test" script). Set these only to force a command for a
# repo that isn't detected — no code change needed to point minions elsewhere.
# MINION_TEST_CMD=make test
# MINION_TEST_FORMAT=tap   # tap | jest | go | exit  (how to read the output)

# ---- Gate hardening (optional) ----
# Run the suite N times and only trust a test that passes EVERY run, so a flaky
# green never earns a ship (default 1; 3 is cheap insurance on flaky repos).
# MINION_TEST_RUNS=3
# Mutation testing: after a fix goes green, perturb its lines and re-run; if the
# test survives every mutation the fix is likely gamed. Max mutants per run
# (default 6; set 0 to disable).
# MINION_MUTANTS=6
